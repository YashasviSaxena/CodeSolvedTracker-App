@{
    ViewBag.Title = "Login";
}

<h2>CodeSolvedTracker Login</h2>

@if (ViewBag.Error != null)
{
    <p style="color:red">@ViewBag.Error</p>
}

<form method="post" asp-action="Login">
    <input type="email" name="email" placeholder="Email" required /><br /><br />
    <input type="password" name="password" placeholder="Password" required /><br /><br />
    <button type="submit">Login</button>
</form>

<hr />

<form asp-action="GoogleLogin" method="get">
    <button style="background:#4285F4;color:white;width:220px;padding:10px;border:none;margin:5px;">
        Continue with Google
    </button>
</form>

<form asp-action="GitHubLogin" method="get">
    <button style="background:#24292e;color:white;width:220px;padding:10px;border:none;margin:5px;">
        Continue with GitHub
    </button>
</form>