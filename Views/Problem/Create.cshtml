<h2>Add Problem</h2>

<form method="post" class="card p-4">
    <input name="Title" class="form-control mb-2" placeholder="Title" />

    <select name="Difficulty" class="form-control mb-2">
        <option>Easy</option>
        <option>Medium</option>
        <option>Hard</option>
    </select>

    <button class="btn btn-primary">Save</button>
</form>