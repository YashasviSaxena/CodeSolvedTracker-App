@{
    ViewData["Title"] = "Sync Platforms";
}

<div class="container">
    <h2 class="text-white mb-4">Sync Your Coding Platforms</h2>

    <div class="row">
        <!-- LeetCode Card -->
        <div class="col-md-6 mb-4">
            <div class="platform-card" onclick="selectPlatform('leetcode')">
                <div class="d-flex align-items-center mb-3">
                    <i class="fab fa-leetcode fa-3x text-warning"></i>
                    <h3 class="mb-0 ms-3 text-white">LeetCode</h3>
                </div>
                <div class="mb-3">
                    <input type="text" id="leetcodeUsername" class="form-control" placeholder="Enter LeetCode username" style="background: rgba(255,255,255,0.1); color: white;">
                </div>
                <button class="btn btn-primary w-100" onclick="syncLeetCode()">
                    <i class="fas fa-sync-alt"></i> Sync LeetCode
                </button>
                <div id="leetcodeStats" class="mt-3"></div>
            </div>
        </div>

        <!-- Codeforces Card -->
        <div class="col-md-6 mb-4">
            <div class="platform-card" onclick="selectPlatform('codeforces')">
                <div class="d-flex align-items-center mb-3">
                    <i class="fas fa-code fa-3x text-info"></i>
                    <h3 class="mb-0 ms-3 text-white">Codeforces</h3>
                </div>
                <div class="mb-3">
                    <input type="text" id="codeforcesUsername" class="form-control" placeholder="Enter Codeforces username" style="background: rgba(255,255,255,0.1); color: white;">
                </div>
                <button class="btn btn-primary w-100" onclick="syncCodeforces()">
                    <i class="fas fa-sync-alt"></i> Sync Codeforces
                </button>
                <div id="codeforcesStats" class="mt-3"></div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="chart-container">
                <h4 class="text-white mb-3">Total Problems Solved</h4>
                <canvas id="totalSolvedChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let totalSolvedChart;

        function selectPlatform(platform) {
            // Remove active class from all cards
            document.querySelectorAll('.platform-card').forEach(card => {
                card.classList.remove('active');
            });
            // Add active class to selected card
            event.currentTarget.classList.add('active');
        }

        async function syncLeetCode() {
            const username = document.getElementById('leetcodeUsername').value;
            if (!username) {
                alert('Please enter LeetCode username');
                return;
            }

            showLoading();

            try {
                const response = await fetch('/Platforms/SyncLeetCode', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({ username: username })
                });

                const data = await response.json();

                if (data.success) {
                    const stats = data.stats;
                    document.getElementById('leetcodeStats').innerHTML = `
                        <div class="alert alert-success">
                            <strong>✅ Synced Successfully!</strong><br>
                            Total Solved: ${stats.totalSolved}<br>
                            Easy: ${stats.easy} | Medium: ${stats.medium} | Hard: ${stats.hard}
                        </div>
                    `;
                    updateTotalSolvedChart();
                } else {
                    document.getElementById('leetcodeStats').innerHTML = `
                        <div class="alert alert-danger">${data.message}</div>
                    `;
                }
            } catch (error) {
                document.getElementById('leetcodeStats').innerHTML = `
                    <div class="alert alert-danger">Error syncing: ${error.message}</div>
                `;
            } finally {
                hideLoading();
            }
        }

        async function syncCodeforces() {
            const username = document.getElementById('codeforcesUsername').value;
            if (!username) {
                alert('Please enter Codeforces username');
                return;
            }

            showLoading();

            try {
                const response = await fetch('/Platforms/SyncCodeforces', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({ username: username })
                });

                const data = await response.json();

                if (data.success) {
                    document.getElementById('codeforcesStats').innerHTML = `
                        <div class="alert alert-success">
                            <strong>✅ Synced Successfully!</strong><br>
                            Total Solved: ${data.totalSolved}
                        </div>
                    `;
                    updateTotalSolvedChart();
                } else {
                    document.getElementById('codeforcesStats').innerHTML = `
                        <div class="alert alert-danger">${data.message}</div>
                    `;
                }
            } catch (error) {
                document.getElementById('codeforcesStats').innerHTML = `
                    <div class="alert alert-danger">Error syncing: ${error.message}</div>
                `;
            } finally {
                hideLoading();
            }
        }

        async function updateTotalSolvedChart() {
            try {
                const response = await fetch('/Platforms/GetConnectedPlatforms');
                const data = await response.json();

                if (data.success && data.platforms) {
                    const ctx = document.getElementById('totalSolvedChart').getContext('2d');

                    if (totalSolvedChart) {
                        totalSolvedChart.destroy();
                    }

                    totalSolvedChart = new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: data.platforms.map(p => p.platform),
                            datasets: [{
                                label: 'Problems Solved',
                                data: [100, 50], // Placeholder - you'll need to fetch actual solved counts
                                backgroundColor: [
                                    'rgba(255, 193, 7, 0.8)',
                                    'rgba(23, 162, 184, 0.8)'
                                ],
                                borderColor: [
                                    'rgb(255, 193, 7)',
                                    'rgb(23, 162, 184)'
                                ],
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: true,
                            plugins: {
                                legend: {
                                    labels: {
                                        color: 'white'
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    ticks: {
                                        color: 'white'
                                    },
                                    grid: {
                                        color: 'rgba(255, 255, 255, 0.1)'
                                    }
                                },
                                x: {
                                    ticks: {
                                        color: 'white'
                                    },
                                    grid: {
                                        color: 'rgba(255, 255, 255, 0.1)'
                                    }
                                }
                            }
                        }
                    });
                }
            } catch (error) {
                console.error('Error updating chart:', error);
            }
        }

        // Load connected platforms on page load
        updateTotalSolvedChart();
    </script>
}